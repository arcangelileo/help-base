# =============================================================================
# HelpBase — Environment Variables
# Copy this file to .env and adjust values for your deployment.
# All variables are prefixed with HELPBASE_.
# =============================================================================

# ---- Security ---------------------------------------------------------------
# Secret key for signing JWT tokens. MUST be changed in production.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(64))"
HELPBASE_SECRET_KEY=change-me-in-production-please

# ---- Application ------------------------------------------------------------
# Enable debug mode (shows /docs Swagger UI, SQL echo)
HELPBASE_DEBUG=false

# Public base URL — used in embeddable widget and public links
HELPBASE_BASE_URL=http://localhost:8000

# ---- Database ---------------------------------------------------------------
# SQLite async connection string (default stores in project root)
HELPBASE_DATABASE_URL=sqlite+aiosqlite:///helpbase.db

# ---- Authentication ---------------------------------------------------------
# JWT token lifetime in minutes (default: 10080 = 7 days)
HELPBASE_JWT_EXPIRE_MINUTES=10080
